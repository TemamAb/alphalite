# ============================================================
# .gitignore — AlphaPro Enterprise
# ============================================================

# ---- Node.js ----
node_modules/
modules/*/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# ---- Environment / Secrets (NEVER commit these) ----
.env
.env.local
.env.*.local
# Keep the example as documentation
!.env.example

# ---- Build outputs ----
modules/dashboard/dist/
modules/dashboard/build/
*.tsbuildinfo

# ---- Logs ----
logs/
*.log
modules/*/logs/

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Editor ----
.vscode/
.idea/
*.swp
*.swo
*.bak

# ---- Docker (local volumes) ----
docker-compose.override.yml
