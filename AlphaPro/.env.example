# ============================================================
# .env.example — AlphaPro Environment Template
# Copy to .env and fill with your actual values.
# NEVER commit .env to version control!
# Set these in the Render Dashboard under Environment Variables.
# ============================================================

# --- Core ---
NODE_ENV=production
TRADING_MODE=LIVE
PORT=10000

# --- Security ---
JWT_SECRET=your_jwt_secret_min_32_chars
ENCRYPTION_KEY=your_encryption_key_64_hex_chars

# --- Blockchain RPC (Alchemy recommended) ---
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# --- API Keys ---
ALCHEMY_API_KEY=your_alchemy_key
INFURA_API_KEY=your_infura_key
OPENAI_API_KEY=sk-proj-...

# --- Pimlico ERC-4337 (Gas Sponsorship) ---
PIMLICO_API_KEY=pim_...
BUNDLER_URL=https://api.pimlico.io/v1/1/rpc?apikey=YOUR_KEY
PAYMASTER_URL=https://api.pimlico.io/v2/1/rpc?apikey=YOUR_KEY
ENTRYPOINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789

# --- Wallet (LIVE trading) ---
WALLET_ADDRESS=0x...
PRIVATE_KEY=0x...

# --- Inter-service ---
BRAIN_URL=http://alphapro-brain:5000

# --- Optional Database ---
DATABASE_URL=postgresql://user:password@host:5432/alphapro
REDIS_URL=redis://localhost:6379

# --- Render-specific ---
ALPHA_AGENT_API_KEY=rnd_...
