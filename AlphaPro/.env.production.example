# =============================================================================
# AlphaPro Enterprise Production Environment Configuration
# =============================================================================
# COPY THIS FILE TO .env AND FILL IN ALL REQUIRED VALUES
# DO NOT COMMIT THIS FILE WITH ACTUAL SECRETS
# =============================================================================

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================
NODE_ENV=production
LOG_LEVEL=info

# =============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# =============================================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/alphapro

# =============================================================================
# REDIS CACHE (REQUIRED)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# SECURITY - JWT (REQUIRED IN PRODUCTION)
# =============================================================================
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-here-min-32-chars

# =============================================================================
# SECURITY - CSRF (RECOMMENDED)
# =============================================================================
CSRF_SECRET=your-csrf-secret-here

# =============================================================================
# SECURITY - ENCRYPTION (REQUIRED)
# =============================================================================
# Encryption key for wallet storage - generate with: openssl rand -hex 32
WALLET_ENCRYPTION_KEY=your-32-byte-encryption-key-in-hex

# =============================================================================
# AUTHENTICATION - MFA (OPTIONAL)
# =============================================================================
# MFA is handled via the service, no additional config needed

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
# Trading mode: PAPER or LIVE
TRADING_MODE=LIVE

# Pimlico configuration for gasless transactions
PIMLICO_API_KEY=your-pimlico-api-key
PIMLICO_BUNDLER_URL=https://bundler.pimlico.io/v2/42161
PIMLICO_PAYMASTER_URL=https://paymaster.pimlico.io/v2/42161
PIMLICO_ENTRYPOINT=0x5FF137D4b0FD96C8E6DC3154AeC59b9d5d38E30e

# Wallet configuration
WALLET_ADDRESS=0xYourWalletAddress
PRIVATE_KEY=0xYourPrivateKeyWithout0xPrefix

# =============================================================================
# BLOCKCHAIN RPC ENDPOINTS (REQUIRED FOR TRADING)
# =============================================================================
# Ethereum
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key

# Polygon
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-api-key

# Arbitrum
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your-api-key

# Optimism
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/your-api-key

# Base
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-api-key

# =============================================================================
# PRICE ORACLES
# =============================================================================
# CoinGecko API (free tier available, get key from coingecko.com)
COINGECKO_API_KEY=your-coingecko-api-key

# Chainlink price feeds (addresses for price feed contracts)
CHAINLINK_ETH_USD=0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419
CHAINLINK_BTC_USD=0xbF5A26E0F8dA4f0C3E2d4f4f4f4f4f4f4f4f4f4f

# =============================================================================
# EXTERNAL APIs
# =============================================================================
DEXSCREENER_API_URL=https://api.dexscreener.com/latest/dex

# =============================================================================
# ALERTING CONFIGURATION (OPTIONAL BUT RECOMMENDED)
# =============================================================================
# PagerDuty
PAGERDUTY_API_KEY=your-pagerduty-api-key
PAGERDUTY_SERVICE_ID=your-pagerduty-service-id

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#alerts

# Email alerts
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=alerts@alphapro.io
ALERT_EMAIL_TO=admin@alphapro.io

# Gas alerts
GAS_ALERT_THRESHOLD=100

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Prometheus metrics endpoint (enabled by default on port 9090)
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=alphapro-api

# =============================================================================
# RATE LIMITING
# =============================================================================
# API rate limits
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Trading rate limits
TRADING_RATE_LIMIT_WINDOW_MS=60000  # 1 minute
TRADING_RATE_LIMIT_MAX=10

# =============================================================================
# DEPLOYMENT
# =============================================================================
# API server
API_PORT=3001
API_HOST=0.0.0.0

# Dashboard
DASHBOARD_PORT=3000
DASHBOARD_HOST=0.0.0.0

# CORS origins (comma-separated)
CORS_ORIGINS=https://app.alphapro.io,https://dashboard.alphapro.io

# =============================================================================
# SESSION & COOKIES
# =============================================================================
SESSION_SECRET=your-session-secret-here
SESSION_MAX_AGE=86400000  # 24 hours

# =============================================================================
# BACKUP & RECOVERY (FOR FUTURE USE)
# =============================================================================
# Backup storage (S3 compatible)
# BACKUP_S3_BUCKET=alphapro-backups
# BACKUP_S3_REGION=us-east-1
# BACKUP_AWS_ACCESS_KEY_ID=your-aws-key
# BACKUP_AWS_SECRET_ACCESS_KEY=your-aws-secret

# =============================================================================
# DEVELOPMENT ONLY - DO NOT USE IN PRODUCTION
# =============================================================================
# These will cause the server to refuse to start in production
# NODE_ENV=production

# =============================================================================
# VERIFICATION CHECKLIST
# =============================================================================
# Before deploying to production, verify:
# [ ] DATABASE_URL is set to production database
# [ ] REDIS_URL is set to production Redis
# [ ] JWT_SECRET is a strong random string (32+ chars)
# [ ] WALLET_ENCRYPTION_KEY is set
# [ ] All RPC URLs point to mainnet
# [ ] All API keys are production keys
# [ ] Alerting channels are configured and tested
# [ ] CORS_ORIGINS only includes production domains
# [ ] Rate limiting is configured appropriately
